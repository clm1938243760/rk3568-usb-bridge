
#!/bin/sh

BASE=/root/usb_bridge
BIN=$BASE/bin
LOG_DIR=$BASE/logs
BOOT_LOG=$LOG_DIR/boot.log

SCAN_PROG=$BIN/scan_patient_capture.py
HID_PROG=$BIN/hid_executor.py
PRINTER_PROG=$BIN/printer_capture.py
UPLOADER_PROG=$BIN/report_uploader.py

PRINTER_DEV=/dev/g_printer0
PRINT_IDLE_TIMEOUT=2.0
REPORT_UPLOAD_URL=http://8.148.73.190:5000/upload
REPORT_UPLOAD_FIELD_NAME=file

mkdir -p $LOG_DIR
mkdir -p $BASE/queue
mkdir -p $BASE/form_queue
mkdir -p $BASE/done
mkdir -p $BASE/form_done
mkdir -p $BASE/error
mkdir -p $BASE/api_raw
mkdir -p $BASE/state
mkdir -p $BASE/report_wait_queue
mkdir -p $BASE/report_wait_done
mkdir -p $BASE/report_print_queue
mkdir -p $BASE/report_pdf_queue
mkdir -p $BASE/report_uploaded
mkdir -p $BASE/report_error

log()
{
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" >> $BOOT_LOG
}

wait_file()
{
    file=$1
    name=$2
    count=0

    while [ ! -e "$file" ]; do
        log "waiting for $name: $file"
        sleep 1
        count=$((count + 1))

        if [ "$count" -ge 60 ]; then
            log "ERROR timeout waiting for $name: $file"
            return 1
        fi
    done

    log "$name ready: $file"
    return 0
}

stop_all()
{
    log "stop old processes"

    pkill -f "$SCAN_PROG" 2>/dev/null
    pkill -f "$HID_PROG" 2>/dev/null
    pkill -f "$PRINTER_PROG" 2>/dev/null
    pkill -f "$UPLOADER_PROG" 2>/dev/null

    # 防止旧版扫码程序干扰
    pkill -f "/root/usb_bridge/bin/scan_capture.py" 2>/dev/null

    rm -f /tmp/scan_patient_capture.pid
    rm -f /tmp/hid_executor.pid
    rm -f /tmp/printer_capture.pid
    rm -f /tmp/report_uploader.pid
}

start_worker()
{
    name=$1
    prog=$2
    out_log=$3
    pid_file=$4

    log "start $name"

    nohup sh -c '
        name="$1"
        prog="$2"
        boot_log="$3"

        while true; do
            echo "[$(date "+%Y-%m-%d %H:%M:%S")] $name run: $prog" >> "$boot_log"
            python3 -u "$prog"
            rc=$?
            echo "[$(date "+%Y-%m-%d %H:%M:%S")] $name exited rc=$rc, restart in 2s" >> "$boot_log"
            sleep 2
        done
    ' sh "$name" "$prog" "$BOOT_LOG" \
        </dev/null >> "$out_log" 2>&1 &

    echo $! > "$pid_file"
    log "$name supervisor pid=$(cat "$pid_file")"
}

start_all()
{
    log "S98usbbridge start"

    stop_all

    # 等 S50usbdevice 创建 HID 节点
    wait_file /dev/hidg0 "keyboard hid" || exit 1
    wait_file /dev/hidg1 "mouse hid" || exit 1
    wait_file "$PRINTER_DEV" "usb printer" || exit 1

    # 不清空 form_queue，防止重启后丢任务
    # 只清理旧 simple queue，避免旧 scan_capture.py 留下的直接输入任务干扰
    rm -f $BASE/queue/*.json 2>/dev/null
    rm -f $BASE/queue/*.work 2>/dev/null

    export PRINTER_DEV
    export PRINT_IDLE_TIMEOUT
    export REPORT_UPLOAD_URL
    export REPORT_UPLOAD_FIELD_NAME

    start_worker "hid_executor" "$HID_PROG" "$LOG_DIR/hid_executor_stdout.log" "/tmp/hid_executor.pid"

    sleep 1

    start_worker "scan_patient_capture" "$SCAN_PROG" "$LOG_DIR/scan_patient_capture_stdout.log" "/tmp/scan_patient_capture.pid"
    start_worker "printer_capture" "$PRINTER_PROG" "$LOG_DIR/printer_capture_stdout.log" "/tmp/printer_capture.pid"
    start_worker "report_uploader" "$UPLOADER_PROG" "$LOG_DIR/report_uploader_stdout.log" "/tmp/report_uploader.pid"

    sleep 1

    ps w | grep -E "scan_patient_capture|hid_executor|printer_capture|report_uploader" | grep -v grep >> $BOOT_LOG

    log "S98usbbridge started"
}

case "$1" in
    start|"")
        start_all
        ;;

    stop)
        log "S98usbbridge stop"
        stop_all
        ;;

    restart)
        log "S98usbbridge restart"
        stop_all
        sleep 1
        start_all
        ;;

    *)
        echo "Usage: $0 {start|stop|restart}"
        exit 1
        ;;
esac

exit 0
